{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/*.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/convert",     "destination": "/api/convert"     },
    { "source": "/api/debug-excel", "destination": "/api/debug-excel" },
    { "source": "/(.*)",            "destination": "/index.html"      }
  ]
}
