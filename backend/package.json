{
  "name": "duimp-converter-backend",
  "version": "1.0.0",
  "description": "Backend para conversão DUIMP → XML",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "build:exe": "pkg . --target node18-win-x64 --output ../dist/duimp-converter.exe"
  },
  "pkg": {
    "scripts": [
      "routes/**/*.js",
      "services/**/*.js"
    ],
    "assets": [
      "node_modules/pdf-parse/lib/**/*",
      "node_modules/pdf-parse/test/data/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  }
}
